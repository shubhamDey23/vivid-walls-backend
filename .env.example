# ---- Server ----
NODE_ENV=development
PORT=5000

# ---- Database (PostgreSQL) ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vivid_walls?schema=public"

# ---- Auth ----
# Use a long, random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET="change-me-to-a-long-random-secret-at-least-16-chars"
JWT_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS=10

# ---- CORS ----
# Comma-separated list of allowed origins, or "*" to allow all
CORS_ORIGIN="*"
